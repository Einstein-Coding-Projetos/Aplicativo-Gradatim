# =========================
# Django
# =========================
DJANGO_ENV=development
DJANGO_DEBUG=1

# Use uma SECRET_KEY forte em dev também (mas não precisa ser a de produção)
DJANGO_SECRET_KEY=

# Hosts e CORS (ajuste conforme seu setup)
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0,192.168.x.x
DJANGO_CORS_ALLOWED_ORIGINS=http://localhost:8081,http://127.0.0.1:8081

# =========================
# Database (PostgreSQL)
# =========================
POSTGRES_DB=
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_HOST=
POSTGRES_PORT=

# Alternativa (se você preferir uma única URL):
# DATABASE_URL=postgresql://gradatim:gradatim_password@db:5432/gradatim

# =========================
# Uploads / Media
# =========================
# Em dev, pode ser local. Em prod, você migraria para S3/Cloud storage.
DJANGO_MEDIA_ROOT=/app/media
DJANGO_STATIC_ROOT=/app/staticfiles

# =========================
# API / Auth (se você usar JWT depois)
# =========================
# JWT_ACCESS_MINUTES=15
# JWT_REFRESH_DAYS=7

# =========================
# Integrações futuras (opcional)
# =========================
# EXTERNAL_AI_API_KEY=
# SENTRY_DSN=
