# Project .gitignore

# Secrets
**/.env
**/.env.*
!**/.env.example

# IDE / OS
.vscode/
.idea/
.DS_Store
Thumbs.db

# Backend (Python / Django)
backend/__pycache__/
backend/*.pyc
backend/*.pyo
backend/*.pyd
backend/.pytest_cache/
backend/.coverage
backend/htmlcov/
backend/.venv/
backend/venv/
backend/env/
backend/db.sqlite3
backend/db.sqlite3-journal
backend/media/
backend/staticfiles/
backend/errors.log

# Python generic cache/tooling
__pycache__/
**/__pycache__/
**/*.pyc
.mypy_cache/
.ruff_cache/
.tox/
.nox/

# Logs / PIDs
*.log
*.pid

# Frontend (Node / Expo)
frontend/node_modules/
frontend/.expo/
frontend/npm-debug.log*
frontend/yarn-error.log*
frontend/.web-build/
frontend/dist/
frontend/build/
frontend/web-build/
frontend/.expo-shared/
frontend/.turbo/
frontend/.parcel-cache/

# Local volumes / data
postgres-data/

# Database dumps/backups
*.sql
*.dump
backup_core_appointment.sql