# URL base da API (dev)
# Se você rodar o app no celular físico, "localhost" NÃO aponta para seu PC.
# Você deve usar o IP da sua máquina na mesma rede (ex: 192.168.0.12).
# Para produção, use um domínio HTTPS e nunca IP
EXPO_PUBLIC_API_URL=http://192.168.x.x:8000

# Opcional: feature flags / ambiente
EXPO_PUBLIC_ENV=development

# Dicas de segurança:
# ✅ .env.local é ignorado pelo Git (seguro para dev)
# ❌ NUNCA commite dados sensíveis ou IPs de produção
# ✅ Para produção, use variáveis de ambiente do servidor (Vercel, AWS, etc)


# Dica prática (importante):
# Se for testar no celular físico, troque:
# http://localhost:8000 → http://SEU_IP:8000
# Se for em emulador Android, às vezes usa:
# http://10.0.2.2:8000 (depende do ambiente)