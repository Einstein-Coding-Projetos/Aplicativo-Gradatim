# =========================
# Django Setup
# =========================
# Mesmo contrato de variáveis para settings.py e settings_prod.py
DJANGO_DEBUG=1
DJANGO_SECRET_KEY=sua-chave-secreta-gerada-aqui
# Gere uma chave: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"

# =========================
# Hosts & CORS
# =========================
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0,192.168.x.x
CORS_ALLOWED_ORIGINS=http://localhost:8081,http://127.0.0.1:8081
CORS_ALLOW_ALL_ORIGINS=0
# Em produção: CORS_ALLOWED_ORIGINS=https://seu-dominio.com

# =========================
# Banco de Dados
# =========================
# Opção 1 — URL única (recomendado para Neon/produção)
DATABASE_URL=postgresql://usuario:senha@host/banco?sslmode=require

# Opção 2 — variáveis individuais (desenvolvimento local)
POSTGRES_DB=apponco_db
POSTGRES_USER=apponco_user
POSTGRES_PASSWORD=sua-senha-aqui
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# =========================
# Produção (descomentar e preencher)
# =========================
# DJANGO_DEBUG=0
# DJANGO_SECRET_KEY=chave-aleatoria-longa
# DJANGO_ALLOWED_HOSTS=seu-dominio.com,www.seu-dominio.com
# CORS_ALLOWED_ORIGINS=https://seu-dominio.com
